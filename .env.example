# BSC Pro - Environment Variables
# Unified Architecture (Supabase Auth only)

# ========== SUPABASE ==========
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ========== AI / GROQ ==========
GROQ_API_KEY=your-groq-api-key

# ========== RATE LIMITING (Upstash Redis) ==========
UPSTASH_REDIS_URL=your-upstash-redis-url
UPSTASH_REDIS_TOKEN=your-upstash-redis-token

# ========== ADMIN SECURITY ==========
ADMIN_SECRET=your-admin-secret

# ========== EMAIL (Optional) ==========
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@bscpro.nl
EMAIL_SUPPORT=support@bscpro.nl

# ========== APP CONFIG ==========
NEXT_PUBLIC_APP_URL=https://www.bscpro.nl
NODE_ENV=production

# ========== ANALYTICS ==========
NEXT_PUBLIC_GA_TRACKING_ID=G-...
NEXT_PUBLIC_UMAMI_WEBSITE_ID=...

# ========== FEATURE FLAGS ==========
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_ENTERPRISE_FORM=true
NEXT_PUBLIC_MAX_FILE_SIZE=10485760  # 10MB in bytes

# ========== SECURITY NOTES ==========
# 1. NEVER commit .env.local to git
# 2. ADMIN_SECRET is server-side only (never NEXT_PUBLIC_ADMIN_SECRET)
# 3. SUPABASE_SERVICE_ROLE_KEY should have minimal permissions
# 4. Use Vercel environment variables for production
