// Helper function to analyze with Groq AI
async function analyzeWithGroq(text: string, categorizationRules?: any[]): Promise<any> {
  const groqApiKey = process.env.GROQ_API_KEY
  if (!groqApiKey) {
    throw new Error('GROQ_API_KEY not configured')
  }

  // Initialize Groq SDK
  const groq = new Groq({ apiKey: groqApiKey })

  // Check text length
  const maxLength = 30000
  let lengthWarning = ''
  if (text.length > maxLength) {
    lengthWarning = 'Waarschuwing: Document is te groot voor volledige analyse. Alleen eerste 30.000 tekens worden geanalyseerd.'
    console.warn(lengthWarning)
  }

  // Split text into pages with markers
  const pages = text.split(/\n\s*\n/).filter(page => page.trim().length > 0)
  let processedText = ''
  
  if (pages.length > 1) {
    // Add page markers for multi-page documents
    processedText = pages.map((page, index) => `--- PAGINA ${index + 1} ---\n${page}`).join('\n\n')
  } else {
    processedText = text
