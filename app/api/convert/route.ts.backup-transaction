// Helper function to check free scan limit directly via RPC
async function checkFreeScanLimit(ipAddress: string, cookieId: string, localStorageId: string): Promise<{ allowed: boolean; error?: string }> {
  if (!supabaseAdmin) {
    return { allowed: false, error: 'Service not initialized' }
  }

  try {
    console.log('Checking free scan limit with EXACT parameters:', { 
      p_ip: ipAddress || 'unknown',
      p_cookie: cookieId || 'no-cookie'
    })
    
    const { data, error } = await supabaseAdmin.rpc('can_perform_free_scan', {
      p_ip: ipAddress || 'unknown',
      p_cookie: cookieId || 'no-cookie'
    })

    if (error) {
      console.error('RPC call failed:', error)
      return { allowed: false, error: 'Database check failed' }
    }

    const allowed = data === true
    console.log('RPC check result:', { allowed })
    
    return { allowed }
  } catch (error) {
    console.error('Exception in free scan check:', error)
    return { allowed: false, error: 'Exception in free scan check' }
  }
}

// Helper function to preprocess bank statement text
function preprocessBankStatementText(text: string): string {
  let processed = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n')
  processed = processed.replace(/\n\s*\n\s*\n/g, '\n\n')
  
  const lines = processed.split('\n')
  const processedLines: string[] = []
  let pageNumber = 1
  
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i]
    processedLines.push(line)
    
    if (line.match(/^\s*Pagina\s+\d+\s+van\s+\d+\s*$/i) || 
        line.match(/^\s*Page\s+\d+\s+of\s+\d+\s*$/i) ||
        line.match(/^\s*\d+\s*\/\s*\d+\s*$/) ||
        (line.trim() === '' && i > 0 && lines[i-1].match(/saldo/i) && i < lines.length - 1 && lines[i+1].match(/^\d{2}-\d{2}-\d{4}/))) {
      processedLines.push(`\n--- PAGINA ${pageNumber} ---\n`)
      pageNumber++
    }
  }
  
  return processedLines.join('\n')
}

// Helper function to analyze with Groq
async function analyzeWithGroq(text: string, categorizationRules?: any[]): Promise<any> {
  const groq = new Groq({ apiKey: process.env.GROQ_API_KEY })
  
  let categorizationInstructions = ''
  if (categorizationRules && categorizationRules.length > 0) {
    const categories = [...new Set(categorizationRules.map(rule => rule.category))]
    categorizationInstructions = `\n\nCATEGORISATIE REGELS:\nWijs elke transactie toe aan één van deze categorieën: ${categories.join(', ')}.`
    
    for (const category of categories) {
      const categoryRules = categorizationRules.filter(rule => rule.category === category)
      const examples = categoryRules.slice(0, 3).map(rule => rule.pattern).join(', ')
      categorizationInstructions += `\n- ${category}: Herken patronen zoals ${examples}`
    }
  }

  const response = await groq.chat.completions.create({
    model: 'llama-3.3-70b-versatile',
    messages: [
      {
        role: 'system',
        content: `Je bent een Nederlandse bankafschrift analist. Je taak is om bankafschriften te analyseren en transacties te extraheren.

INSTRUCTIES:
1. Analyseer het bankafschrift nauwkeurig
2. Extraheer ALLE transacties in chronologische volgorde
3. Bereken het saldo na elke transactie
4. Identificeer de bank (ABN AMRO, ING, Rabobank, etc.)
5. Identificeer het rekeningnummer
6. Bepaal de periode (van-tot)
7. Bereken het beginsaldo en eindsaldo
8. Per pagina: noteer beginsaldo, eindsaldo en aantal transacties${categorizationInstructions}

BELANGRIJK:
- Gebruik het exacte datumformaat DD-MM-YYYY
- Bedragen zijn in Euro, gebruik . als decimaal scheidingsteken
- Negatieve bedragen zijn uitgaven (met minteken)
- Positieve bedragen zijn inkomsten (zonder minteken)
- Saldo na transactie MOET correct berekend worden
- Transactietype (overboeking, incasso, geldautomaat, etc.)

Geef antwoord in dit JSON formaat:
{
  "bank": "Banknaam",
  "account_number": "Rekeningnummer",
  "period": {
    "from": "DD-MM-YYYY",
    "to": "DD-MM-YYYY"
  },
  "opening_balance": 1234.56,
  "closing_balance": 9876.54,
  "page_analysis": [
    {
      "page": 1,
      "opening_balance": 1234.56,
      "closing_balance": 2345.67,
      "transaction_count": 10
    }
  ],
  "transactions": [
    {
      "date": "01-01-2025",
      "description": "Omschrijving",
      "amount": -50.00,
      "balance_after": 1184.56,
      "type": "incasso"
    }
  ],
  "confidence_score": 0.95,
  "notes": "Eventuele opmerkingen over de analyse"
}`
      },
      {
        role: 'user',
        content: `Analyseer dit bankafschrift:\n\n${text.substring(0, 30000)}`
      }
    ],
    temperature: 0.1,
    response_format: { type: 'json_object' }
  })

  if (!response.choices || response.choices.length === 0) {
    throw new Error('Geen response van Groq API')
  }

  return JSON.parse(response.choices[0].message.content)
}

