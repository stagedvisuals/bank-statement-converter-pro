// POST endpoint for bank statement conversion with STRICT CREDIT LOGIC
export async function POST(request: NextRequest) {
  try {
    // ========== STAP 1: AUTHENTICATIE CHECK ==========
    const authHeader = request.headers.get('authorization')
    if (!authHeader || !authHeader.startsWith('Bearer ')) {
      return NextResponse.json(
        { error: 'Authenticatie vereist. Log in om deze actie uit te voeren.' },
        { status: 401 }
      )
    }

    const token = authHeader.replace('Bearer ', '')
    
    const { data: { user }, error: authError } = await supabase.auth.getUser(token)
    
    if (authError || !user) {
      return NextResponse.json(
        { error: 'Ongeldige authenticatie. Log opnieuw in.' },
        { status: 401 }
      )
    }

    // ========== STAP 2: CREDIT PRE-CHECK ==========
    console.log(`🔍 Credit check voor gebruiker: ${user.id}`)
    
    const { data: profile, error: profileError } = await supabase
      .from('profiles')
      .select('credits')
      .eq('user_id', user.id)
      .single()

    if (profileError) {
      console.error('Profile fetch error:', profileError)
      const { data: userCredits, error: creditsError } = await supabase
        .from('user_credits')
        .select('remaining_credits')
        .eq('user_id', user.id)
        .single()

      if (creditsError) {
        console.log('Geen credits gevonden voor gebruiker, gebruik default 0')
      } else if (userCredits?.remaining_credits <= 0) {
        return NextResponse.json(
          { 
            error: 'Je credits zijn op. Upgrade je plan op bscpro.nl om verder te gaan.',
            remaining_credits: 0,
            upgrade_url: 'https://www.bscpro.nl/#pricing'
          },
          { status: 402 }
        )
      }
    } else if (profile?.credits <= 0) {
      return NextResponse.json(
        { 
          error: 'Je credits zijn op. Upgrade je plan op bscpro.nl om verder te gaan.',
          remaining_credits: 0,
          upgrade_url: 'https://www.bscpro.nl/#pricing'
        },
        { status: 402 }
      )
    }

    const currentCredits = profile?.credits || 0
    console.log(`✅ Credits beschikbaar: ${currentCredits}`)

    // ========== STAP 3: BESTAND VERWERKING ==========
    const formData = await request.formData()
    const file = formData.get('file') as File
    
    if (!file) {
      return NextResponse.json(
        { error: 'Geen bestand geüpload' },
        { status: 400 }
      )
    }

    if (file.type !== 'application/pdf') {
      return NextResponse.json(
        { error: 'Alleen PDF bestanden worden ondersteund' },
        { status: 400 }
      )
    }

    const buffer = await file.arrayBuffer()
    const pdfText = await extractTextFromPDF(buffer)
    
    if (!pdfText || pdfText.trim().length === 0) {
      return NextResponse.json(
        { error: 'Kon geen tekst extraheren uit PDF. Controleer of het een gescand PDF is.' },
        { status: 400 }
      )
    }

    // ========== STAP 4: AI-SCAN UITVOEREN ==========
    console.log('🚀 AI-scan starten...')
    const processedText = preprocessBankStatementText(pdfText)
    
    let categorizationRules = []
    try {
      const { data: rules, error: rulesError } = await supabase
        .from('categorization_rules')
        .select('*')
        .eq('user_id', user.id)
        .order('priority', { ascending: false })

      if (!rulesError && rules && rules.length > 0) {
        categorizationRules = rules
      } else {
        const { data: defaultRules } = await supabase
          .from('default_categorization_rules')
          .select('*')
          .order('priority', { ascending: false })
        
        if (defaultRules) categorizationRules = defaultRules
      }
    } catch (rulesError) {
      console.error('Error fetching categorization rules:', rulesError)
    }

    const analysisResult = await analyzeWithGroq(processedText, categorizationRules)
    
    // ========== STAP 5: VALIDATIE ==========
    if (!analysisResult || !analysisResult.transactions || !Array.isArray(analysisResult.transactions)) {
      console.error('Ongeldige AI response:', analysisResult)
      return NextResponse.json(
        { error: 'AI scan mislukt. Kon geen transacties extraheren.' },
        { status: 500 }
      )
    }

    if (analysisResult.transactions.length === 0) {
      console.error('Geen transacties gevonden in AI response')
      return NextResponse.json(
        { error: 'Geen transacties gevonden in het bankafschrift.' },
        { status: 400 }
      )
    }

    // ========== STAP 6: CREDIT AFGESCHREVEN (ALLEEN BIJ SUCCES) ==========
    console.log(`✅ Scan succesvol! ${analysisResult.transactions.length} transacties geëxtraheerd.`)
    console.log('💰 Credit aftrekken...')
    
    // 🔥 BEWIJS: Database update PAS na succesvolle validatie
    try {
      const { error: updateError } = await supabase
        .from('profiles')
        .update({ 
          credits: currentCredits - 1,
          updated_at: new Date().toISOString()
        })
        .eq('user_id', user.id)

      if (updateError) {
        console.error('Credit update error:', updateError)
        const { error: creditsUpdateError } = await supabase
          .from('user_credits')
          .update({ 
            remaining_credits: currentCredits - 1,
            used_credits: () => 'used_credits + 1',
            updated_at: new Date().toISOString()
          })
          .eq('user_id', user.id)

        if (creditsUpdateError) {
          console.error('Fallback credit update ook mislukt:', creditsUpdateError)
        }
      }
      
      console.log(`✅ 1 credit afgeschreven. Nieuw saldo: ${currentCredits - 1}`)
    } catch (updateError) {
      console.error('Exception tijdens credit update:', updateError)
    }

    // ========== STAP 7: SUCCESS RESPONSE ==========
    return NextResponse.json({
      success: true,
      message: `Bankafschrift succesvol geanalyseerd. ${analysisResult.transactions.length} transacties gevonden.`,
      data: analysisResult,
      credits_used: 1,
      credits_remaining: currentCredits - 1,
      timestamp: new Date().toISOString()
    })

  } catch (error) {
    console.error('Convert API error:', error)
    
    return NextResponse.json(
      { 
        error: 'Conversie mislukt: ' + (error instanceof Error ? error.message : 'Onbekende fout'),
        credits_used: 0,
        note: 'Er is geen credit afgeschreven omdat de scan is mislukt.'
      },
      { status: 500 }
    )
  }
}

